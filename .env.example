# Local-dev env. In production the PLATFORM injects these — you normally don't set them here.
# Copy to .env for local runs:  cp .env.example .env

# Claude API key. Platform-provided in production; set here only for local dev or as an override.
ANTHROPIC_API_KEY=

# Leave unset locally so ?fake_email= works; the platform sets NODE_ENV=production.
# NODE_ENV=production
